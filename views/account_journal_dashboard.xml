<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_account_bank_statement_from_journal" model="ir.actions.act_window">
        <field name="name">Relevés bancaires</field>
        <field name="res_model">account.bank.statement</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_journal_id': active_id, 'default_journal_id': active_id}</field>
        <field name="domain">[('journal_id', '=', active_id)]</field>
    </record>

    <record id="view_account_journal_dashboard_kanban_inherit_bank_buttons" model="ir.ui.view">
        <field name="name">account.journal.dashboard.kanban.inherit.bank.buttons</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.account_journal_dashboard_kanban_view"/>
        <field name="arch" type="xml">

            <xpath expr="//t[@t-name='JournalBodyBankCash']//button[@id='all_transactions_btn']" position="after">

                <button type="action"
                        name="%(action_account_bank_statement_from_journal)d"
                        class="btn btn-secondary"
                        context="{'active_id': id}"
                        invisible="type not in ('bank', 'cash')">
                    Relevés
                </button>

                <button type="action"
                        name="%(account_statement_import_file.account_statement_import_action)d"
                        class="btn btn-secondary"
                        context="{'default_journal_id': id}"
                        invisible="type != 'bank'">
                    Import CAMT
                </button>

            </xpath>

        </field>
    </record>

</odoo>
